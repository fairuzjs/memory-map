// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  role          Role       @default(USER)
  name          String
  email         String     @unique
  password      String
  image         String?
  bio           String?
  instagram     String?
  tiktok        String?
  facebook      String?
  points        Int        @default(0)
  createdAt     DateTime   @default(now())
  memories       Memory[]
  comments       Comment[]
  reactions      Reaction[]
  feedbacks      Feedback[]
  reports        Report[]
  notifications  Notification[] @relation("ReceivedNotifications")
  actions        Notification[] @relation("TriggeredNotifications")
  collaborations MemoryCollaborator[]
  streakData     UserStreak?
  streakBadges   UserStreakBadge[]
  pinnedBadge    Int?
  inventories    UserInventory[]
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  isRead    Boolean          @default(false)
  userId    String           @map("user_id")
  actorId   String           @map("actor_id")
  memoryId  String?          @map("memory_id")
  createdAt DateTime         @default(now())

  user   User    @relation("ReceivedNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actor  User    @relation("TriggeredNotifications", fields: [actorId], references: [id], onDelete: Cascade)
  memory Memory? @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([actorId])
}

enum NotificationType {
  COMMENT
  REACTION
  REPLY
  COLLABORATION_INVITE
}

enum Role {
  USER
  ADMIN
}

model Memory {
  id           String     @id @default(cuid())
  title        String
  story        String     @db.Text
  date         DateTime
  latitude     Float
  longitude    Float
  locationName String?
  emotion      Emotion
  isPublic     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos        Photo[]
  comments      Comment[]
  reactions     Reaction[]
  tags          Tag[]
  reports       Report[]
  notifications Notification[]
  collaborators MemoryCollaborator[]
}

enum Emotion {
  HAPPY
  SAD
  NOSTALGIC
  EXCITED
  PEACEFUL
  GRATEFUL
  ROMANTIC
  ADVENTUROUS
}

model Photo {
  id       String  @id @default(cuid())
  url      String
  caption  String?
  memoryId String
  memory   Memory  @relation(fields: [memoryId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  createdAt DateTime  @default(now())
  userId    String
  memoryId  String
  parentId  String?
  user      User      @relation(fields: [userId], references: [id])
  memory    Memory    @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("Replies")
}

model Reaction {
  id       String       @id @default(cuid())
  type     ReactionType
  userId   String
  memoryId String
  user     User         @relation(fields: [userId], references: [id])
  memory   Memory       @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  
  @@unique([userId, memoryId])
}

enum ReactionType {
  LOVE
  WOW
  SAD
  LAUGH
}

model Tag {
  id       String   @id @default(cuid())
  name     String   @unique
  memories Memory[]
}

model MemoryCollaborator {
  id        String              @id @default(cuid())
  memoryId  String              @map("memory_id")
  userId    String              @map("user_id")
  status    CollaboratorStatus  @default(PENDING)
  createdAt DateTime            @default(now())

  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([memoryId, userId])
  @@index([memoryId])
  @@index([userId])
}

enum CollaboratorStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Feedback {
  id         String             @id @default(cuid())
  message    String             @db.Text
  imageUrl   String?
  adminReply String?            @db.Text
  status     FeedbackStatus     @default(PENDING)
  category   FeedbackCategory   @default(SUGGESTION)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum FeedbackStatus {
  PENDING
  READ
  REPLIED
}

enum FeedbackCategory {
  SUGGESTION
  BUG
  QUESTION
  OTHER
}

model Report {
  id        String       @id @default(cuid())
  reason    ReportReason
  details   String?      @db.Text
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  
  reporterId String
  reporter   User        @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  
  memoryId  String
  memory    Memory      @relation(fields: [memoryId], references: [id], onDelete: Cascade)
}

enum ReportReason {
  SARA
  PORNOGRAPHY
  VIOLENCE
  SPAM
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

model UserStreak {
  id              String    @id @default(cuid())
  userId          String    @unique
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  totalActiveDays Int       @default(0)
  lastClaimedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserStreakBadge {
  id        String   @id @default(cuid())
  userId    String
  milestone Int
  earnedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, milestone])
  @@index([userId])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

// ── Reward / Shop System ──────────────────────────────────────

enum ItemType {
  AVATAR_FRAME
  PROFILE_BANNER
  MEMORY_CARD_THEME
  USERNAME_DECORATION
}

model ShopItem {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Int
  type        ItemType
  value       String   // CSS gradient / identifier used by frontend
  previewColor String? // Accent hex for card UI preview
  createdAt   DateTime @default(now())

  owners UserInventory[]
}

model UserInventory {
  id         String   @id @default(cuid())
  userId     String
  itemId     String
  isEquipped Boolean  @default(false)
  acquiredAt DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
}
