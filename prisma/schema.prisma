// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  role            Role     @default(USER)
  username        String?  @unique
  name            String
  email           String   @unique
  password        String
  image           String?
  bio             String?
  isVerified      Boolean  @default(false) // Admin-granted verified badge (blue checkmark)
  isEmailVerified Boolean  @default(false) // User email verified (gates features)
  instagram       String?
  tiktok          String?
  facebook        String?
  points          Int      @default(0)
  createdAt       DateTime @default(now())

  // ── Moderation ──────────────────────────────────────
  bannedUntil           DateTime?
  bannedReason          String?
  globalChatBannedUntil DateTime?

  // ── Premium ──────────────────────────────
  isPremium              Boolean   @default(false)
  premiumExpiresAt       DateTime? // null = belum pernah premium
  freeGachaPullsUsed     Int       @default(0) // Reset setiap hari Senin
  freeGachaPullsResetAt  DateTime? // Kapan weekly reset berikutnya
  streakFreezesUsed      Int       @default(0) // Reset setiap tanggal 1
  streakFreezesResetAt   DateTime? // Kapan monthly reset berikutnya
  premiumItemsClaimed    Boolean   @default(false) // Apakah sudah klaim item premium (bingkai + banner)
  hasCompletedOnboarding Boolean   @default(false) // Apakah sudah menyelesaikan/skip tutorial onboarding
  hasSeenWelcomeGuide    Boolean   @default(false) // Apakah sudah melihat intro welcome (arahkan ke Buku Panduan)

  memories          Memory[]
  comments          Comment[]
  reactions         Reaction[]
  feedbacks         Feedback[]
  reports           Report[]
  notifications     Notification[]           @relation("ReceivedNotifications")
  actions           Notification[]           @relation("TriggeredNotifications")
  collaborations    MemoryCollaborator[]
  streakData        UserStreak?
  streakBadges      UserStreakBadge[]
  pinnedBadge       Int?
  inventories       UserInventory[]
  topupOrders       TopupOrder[]
  stickerPlacements MemoryStickerPlacement[]
  gachaLogs         GachaLog[]
  followers         Follow[]                 @relation("UserFollowers")
  following         Follow[]                 @relation("UserFollowing")
  verificationCodes VerificationCode[]
  premiumOrders     PremiumOrder[]
  albums            Album[]
  auditLogs         AdminAuditLog[]
  albumCollaborators AlbumCollaborator[]
  albumStickyNotes   AlbumStickyNote[]
  albumChatMessages  AlbumChatMessage[]
  globalChatMessages        GlobalChatMessage[] @relation("UserGlobalChatMessages")
  deletedGlobalChatMessages GlobalChatMessage[] @relation("DeletedGlobalChatMessages")
  banAppeals                BanAppeal[]
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  isRead    Boolean          @default(false)
  userId    String           @map("user_id")
  actorId   String           @map("actor_id")
  memoryId  String?          @map("memory_id")
  albumId   String?          @map("album_id")
  createdAt DateTime         @default(now())

  user   User    @relation("ReceivedNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actor  User    @relation("TriggeredNotifications", fields: [actorId], references: [id], onDelete: Cascade)
  memory Memory? @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  album  Album?  @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([actorId])
  @@index([albumId])
}

enum NotificationType {
  COMMENT
  REACTION
  REPLY
  COLLABORATION_INVITE
  FOLLOW
  PREMIUM_ACTIVATED
  ALBUM_INVITE
  ALBUM_LEAVE
}

model Follow {
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

enum Role {
  USER
  ADMIN
}

model Memory {
  id                String                   @id @default(cuid())
  title             String
  story             String                   @db.Text
  date              DateTime
  latitude          Float
  longitude         Float
  locationName      String?
  emotion           Emotion
  isPublic          Boolean                  @default(true)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  userId            String
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos            Photo[]
  comments          Comment[]
  reactions         Reaction[]
  tags              Tag[]
  reports           Report[]
  notifications     Notification[]
  collaborators     MemoryCollaborator[]
  stickerPlacements MemoryStickerPlacement[]

  // Audio clip fields
  audioUrl       String? // URL file MP3 di Supabase Storage
  audioBucket    String? // "public_uploads" / "private_uploads"
  audioPath      String? // Storage path untuk management
  audioStartTime Float? // Detik mulai clip
  audioDuration  Int? // Durasi clip dalam detik (10, 15, atau 30)
  audioFileName  String? // Nama file asli untuk display

  // Spotify integration
  spotifyTrackId      String? // Spotify Track ID
  spotifyAccessSource SpotifyAccessSource? // Sumber akses saat dipasang

  // Premium map marker
  markerStyle String? // Premium marker style ID (e.g. "royal-gold")

  // Cover image fields
  coverImage     String? // URL cover yang sudah di-crop (Supabase)
  coverPositionX Float?  @default(0) // Posisi X untuk re-edit
  coverPositionY Float?  @default(0) // Posisi Y untuk re-edit
  coverScale     Float?  @default(1) // Zoom level untuk re-edit
  coverRotation  Float?  @default(0) // Rotasi dalam derajat

  isPinned Boolean       @default(false)
  albums   AlbumMemory[]

  @@index([userId])
  @@index([createdAt])
}

enum Emotion {
  HAPPY
  SAD
  NOSTALGIC
  EXCITED
  PEACEFUL
  GRATEFUL
  ROMANTIC
  ADVENTUROUS
}

enum SpotifyAccessSource {
  PREMIUM
  SHOP_PERMANENT
  BOTH
}

model Photo {
  id       String  @id @default(cuid())
  url      String
  caption  String?
  memoryId String
  memory   Memory  @relation(fields: [memoryId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  createdAt DateTime  @default(now())
  userId    String
  memoryId  String
  parentId      String?
  voiceUrl      String?
  voiceDuration Int?
  user      User      @relation(fields: [userId], references: [id])
  memory    Memory    @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("Replies")

  @@index([memoryId])
  @@index([parentId])
  @@index([userId])
}

model Reaction {
  id       String       @id @default(cuid())
  type     ReactionType
  userId   String
  memoryId String
  user     User         @relation(fields: [userId], references: [id])
  memory   Memory       @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@unique([userId, memoryId])
  @@index([memoryId])
}

enum ReactionType {
  LOVE
  WOW
  SAD
  LAUGH
}

model Tag {
  id       String   @id @default(cuid())
  name     String   @unique
  memories Memory[]
}

model MemoryCollaborator {
  id        String             @id @default(cuid())
  memoryId  String             @map("memory_id")
  userId    String             @map("user_id")
  status    CollaboratorStatus @default(PENDING)
  createdAt DateTime           @default(now())

  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([memoryId, userId])
  @@index([memoryId])
  @@index([userId])
}

enum CollaboratorStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Feedback {
  id         String           @id @default(cuid())
  message    String           @db.Text
  imageUrl   String?
  adminReply String?          @db.Text
  status     FeedbackStatus   @default(PENDING)
  category   FeedbackCategory @default(SUGGESTION)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum FeedbackStatus {
  PENDING
  READ
  REPLIED
}

enum FeedbackCategory {
  SUGGESTION
  BUG
  QUESTION
  OTHER
}

model Report {
  id        String       @id @default(cuid())
  reason    ReportReason
  details   String?      @db.Text
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  memoryId String
  memory   Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
}

enum ReportReason {
  SARA
  PORNOGRAPHY
  VIOLENCE
  SPAM
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

model UserStreak {
  id              String    @id @default(cuid())
  userId          String    @unique
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  totalActiveDays Int       @default(0)
  activeDates     String[]  @default([])
  lastClaimedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserStreakBadge {
  id        String   @id @default(cuid())
  userId    String
  milestone Int
  earnedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, milestone])
  @@index([userId])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model VerificationCode {
  id        String   @id @default(cuid())
  userId    String
  email     String
  code      String // 6-digit OTP
  expires   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([userId])
}

model PreRegisterOtp {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String // hashed password, stored temporarily
  code      String // 6-digit OTP
  expires   DateTime
  createdAt DateTime @default(now())
}

// ── Reward / Shop System ──────────────────────────────────────

enum ItemType {
  AVATAR_FRAME
  PROFILE_BANNER
  MEMORY_CARD_THEME
  USERNAME_DECORATION
  MEMORY_STICKER
  PREMIUM_FEATURE
}

model ShopItem {
  id           String   @id @default(cuid())
  name         String
  description  String
  price        Int
  type         ItemType
  value        String // CSS gradient / identifier used by frontend
  previewColor String? // Accent hex for card UI preview
  createdAt    DateTime @default(now())

  owners            UserInventory[]
  stickerPlacements MemoryStickerPlacement[]
  gachaLogs         GachaLog[]
}

model UserInventory {
  id         String   @id @default(cuid())
  userId     String
  itemId     String
  isEquipped Boolean  @default(false)
  acquiredAt DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
}

// ── Topup System ──────────────────────────────────────────────

model TopupOrder {
  id         String      @id @default(cuid())
  userId     String
  amount     Int // nominal point yang dibeli
  price      Int // harga dalam rupiah
  status     TopupStatus @default(PENDING)
  note       String? // catatan dari admin
  proofImage String? // URL bukti transfer dari user
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

enum TopupStatus {
  PENDING
  COMPLETED
  CANCELLED
}

// ── Memory Sticker Placements ──────────────────────────────────────

model MemoryStickerPlacement {
  id         String   @id @default(cuid())
  memoryId   String   @map("memory_id")
  userId     String   @map("user_id")
  itemId     String   @map("item_id")
  posX       Float    @default(50) // % dari lebar area foto (0-100)
  posY       Float    @default(50) // % dari tinggi area foto (0-100)
  rotation   Float    @default(0) // derajat
  scale      Float    @default(1.0) // 0.5 - 2.0
  zIndex     Int      @default(10)
  customText String? // teks kustom user (maks 20 karakter)
  createdAt  DateTime @default(now())

  memory Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item   ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([memoryId])
  @@index([userId])
}

// ── Gacha / Mystery Box System ─────────────────────────────────

model GachaLog {
  id           String   @id @default(cuid())
  userId       String
  itemId       String
  tier         String // "BASIC" | "ELITE" | "EPIC" | "LEGEND"
  isDuplicate  Boolean  @default(false)
  refundAmount Int      @default(0)
  createdAt    DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Premium Subscription System ────────────────────────────────

model PremiumOrder {
  id           String      @id @default(cuid())
  userId       String
  durationDays Int // 30
  price        Int // harga dalam Rupiah (29900)
  status       TopupStatus @default(PENDING) // reuse: PENDING / COMPLETED / CANCELLED
  proofImage   String? // bukti transfer
  note         String? // catatan admin
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Album {
  id                  String              @id @default(cuid())
  userId              String
  name                String
  description         String?             @db.Text
  coverImage          String?
  pendingCoverImage   String?             // Cover yang sedang diajukan oleh Editor
  pendingCoverActorId String?             // Siapa Editor yang mengajukan
  icon                String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  memories            AlbumMemory[]
  collaborators       AlbumCollaborator[]
  notifications       Notification[]
  stickyNotes         AlbumStickyNote[]
  chatMessages        AlbumChatMessage[]

  @@index([userId])
  @@map("albums")
}

model AlbumMemory {
  albumId  String
  memoryId String
  album    Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  memory   Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@id([albumId, memoryId])
  @@index([albumId])
  @@index([memoryId])
  @@map("album_memories")
}

enum AlbumCollaboratorRole {
  OWNER
  EDITOR
  CONTRIBUTOR
}

enum AlbumCollaboratorStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model AlbumCollaborator {
  id        String                  @id @default(cuid())
  albumId   String                  @map("album_id")
  userId    String                  @map("user_id")
  role      AlbumCollaboratorRole   @default(CONTRIBUTOR)
  status    AlbumCollaboratorStatus @default(PENDING)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([albumId, userId])
  @@index([albumId])
  @@index([userId])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  metadata   String?  @db.Text
  createdAt  DateTime @default(now())

  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

model AlbumStickyNote {
  id        String   @id @default(cuid())
  content   String   // Maksimal 100 karakter
  color     String   // "yellow" | "pink" | "cyan" | "orange"
  rotation  Int      // Kemiringan rotasi acak
  createdAt DateTime @default(now())
  userId    String
  albumId   String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId])
  @@index([userId])
  @@map("album_sticky_notes")
}

model AlbumChatMessage {
  id        String   @id @default(cuid())
  content   String   // Maksimal 500 karakter
  createdAt DateTime @default(now())
  userId    String
  albumId   String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId])
  @@index([userId])
  @@map("album_chat_messages")
}

model GlobalChatMessage {
  id          String    @id @default(cuid())
  content     String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedById String?

  userId      String?
  user        User?      @relation("UserGlobalChatMessages", fields: [userId], references: [id], onDelete: Cascade)
  
  // ── Guest fields ──────────────────────────────────────────────
  isGuest     Boolean   @default(false)
  guestId     String?
  guestName   String?

  deletedBy   User?     @relation("DeletedGlobalChatMessages", fields: [deletedById], references: [id], onDelete: SetNull)

  // ── Reply fields ──────────────────────────────────────────────
  replyToId   String?
  replyTo     GlobalChatMessage?  @relation("ChatReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies     GlobalChatMessage[] @relation("ChatReplies")

  @@index([createdAt])
  @@index([userId])
  @@index([isDeleted, createdAt])
  @@index([replyToId])
  @@map("global_chat_messages")
}

enum BanAppealStatus {
  PENDING
  APPROVED
  REJECTED
}

model BanAppeal {
  id         String          @id @default(cuid())
  userId     String
  reason     String          @db.Text
  adminNotes String?         @db.Text
  status     BanAppealStatus @default(PENDING)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}
