# ============================================================
# MEMORY MAP — Environment Variables Template
# ============================================================
# CARA PENGGUNAAN:
# 1. Salin file ini: cp .env.example .env
# 2. Isi semua nilai yang dibutuhkan
# 3. JANGAN PERNAH commit file .env ke Git
# ============================================================

# ========================
# DATABASE (Supabase / PostgreSQL)
# ========================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# ========================
# NEXTAUTH
# ========================
# URL aplikasi (ganti saat deploy ke production)
NEXTAUTH_URL="http://localhost:3000"

# Secret acak minimal 32 karakter — generate dengan:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_32_CHAR_SECRET"

# ========================
# SUPABASE
# ========================
# Dari: https://supabase.com/dashboard > Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# anon/public key — AMAN untuk di-expose ke client
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# service_role key — RAHASIA, hanya boleh di server-side
# PERINGATAN: Key ini memiliki akses penuh dan melewati RLS!
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ========================
# EMAIL (SMTP)
# ========================
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=your-email@gmail.com

# Untuk Gmail: gunakan App Password (bukan password utama)
# Generate di: https://myaccount.google.com/apppasswords
EMAIL_SERVER_PASSWORD=your-gmail-app-password

EMAIL_FROM="MemoryMap <noreply@your-domain.com>"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ========================
# SPOTIFY API
# ========================
# Dari: https://developer.spotify.com/dashboard > App Settings
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# ========================
# MAPBOX
# ========================
# Dari: https://account.mapbox.com/access-tokens/
# Batasi token hanya untuk URL domain Anda di dashboard Mapbox!
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.eyJ1...your-mapbox-token
